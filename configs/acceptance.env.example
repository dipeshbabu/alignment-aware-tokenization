# Copy to configs/acceptance.env, edit paths/commands, then:
#   source configs/acceptance.env
#   uv run bash scripts/sh/run_acceptance_matrix.sh

# Recommended independent diagnostic judge. For official HarmBench/JBB metrics,
# prefer each benchmark's native judge inside HARMBENCH_CMD/JAILBREAKBENCH_CMD.
export JUDGE_MODEL="meta-llama/Llama-Guard-4-12B"
export JUDGE_TYPE="causal_lm"
export JUDGE_DEVICE="cuda"
export JUDGE_THRESHOLD="0.5"
export JUDGE_BS="4"

# External benchmark checkouts.
export HARMBENCH_DIR="/path/to/HarmBench"
export JAILBREAKBENCH_DIR="/path/to/jailbreakbench"
export XSTEST_FILE="/path/to/xstest.jsonl"

# These commands must write benchmark-native JSON into $AAT_OUT_DIR.
# They receive:
#   AAT_SETTING_NAME, AAT_MODEL_NAME, AAT_TOKENIZER_NAME, AAT_ADAPTER,
#   AAT_PROBE, AAT_OUT_DIR, AAT_JUDGE_MODEL
export HARMBENCH_CMD='cd "$HARMBENCH_DIR" && bash your_harmbench_eval.sh "$AAT_MODEL_NAME" "$AAT_TOKENIZER_NAME" "$AAT_ADAPTER" "$AAT_OUT_DIR/harmbench.json"'
export JAILBREAKBENCH_CMD='cd "$JAILBREAKBENCH_DIR" && python your_jbb_eval.py --model "$AAT_MODEL_NAME" --tokenizer "$AAT_TOKENIZER_NAME" --adapter "$AAT_ADAPTER" --out "$AAT_OUT_DIR/jailbreakbench.json"'
export XSTEST_CMD='python scripts/run_xstest_external.py --model "$AAT_MODEL_NAME" --tokenizer "$AAT_TOKENIZER_NAME" --adapter "$AAT_ADAPTER" --input "$XSTEST_FILE" --out "$AAT_OUT_DIR/xstest.json"'
